# Syscalls denied inside the Emacs sandbox.
# One syscall per line; '#' starts a comment.
# This list is cribbed from firejail's default seccomp filter, with a few
# deliberate omissions documented in the README.
#
# Re-run emacs-sandbox-setup.sh after editing to regenerate the BPF.

# Loadable kernel modules
create_module
delete_module
finit_module
get_kernel_syms
init_module
query_module

# Kernel exec / reboot
kexec_file_load
kexec_load
reboot

# Privileged filesystem ops
#
# mount, umount2, and pivot_root are deliberately NOT denied: a nested
# bubblewrap sandbox (e.g. one launched from a terminal inside Emacs) needs
# them to build its mount namespace (bind mounts, then pivot_root onto the new
# root and umount2(MNT_DETACH) of the old one). Denying them makes nested
# sandboxing fail at "Failed to make / slave: Operation not permitted". This
# widens kernel attack surface (the mount family has a CVE history) but does
# NOT weaken the filesystem boundary: the outer sandbox's read-only binds are
# created in a less-privileged user namespace, so their MS_RDONLY flags are
# locked and a nested user namespace cannot clear them. Legacy umount (below)
# stays denied -- bwrap uses umount2.
umount
swapon
swapoff
quotactl
nfsservctl
uselib

# fanotify/file-handle abuse (open_by_handle_at + name_to_handle_at lets you
# open files by NFS-style handles, bypassing path-based MAC checks)
name_to_handle_at
open_by_handle_at

# Time setters
clock_settime
settimeofday
stime

# Process accounting, low-level kernel
acct
sysfs
_sysctl

# Performance / tracing / kernel introspection
perf_event_open
ptrace
kcmp
lookup_dcookie

# Key management
add_key
keyctl
request_key

# Memory policy / NUMA
mbind
move_pages
set_mempolicy

# Namespaces: block joining EXISTING namespaces via setns. Creating NEW
# namespaces (unshare / clone with CLONE_NEW*) is intentionally left allowed --
# a nested sandbox needs it to build its own user, mount, net, and pid
# namespaces. bwrap created THIS sandbox before the filter loaded, so setns
# here only constrains code running inside it.
setns

# io_uring -- broad attack surface, has had multiple LPE CVEs
io_uring_setup
io_uring_enter
io_uring_register

# eBPF -- broad attack surface, frequent CVE source
bpf

# Userfaultfd -- has been used to widen race-window LPEs
userfaultfd

# Misc legacy
personality
ustat
vm86
vm86old
